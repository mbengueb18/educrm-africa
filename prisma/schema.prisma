// ============================================
// TalibCRM — Prisma Schema
// Stack: Next.js 15 + Prisma 6 + PostgreSQL
// Architecture: Multi-tenant (shared DB, shared schema)
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooler (6543, pgbouncer) — runtime serverless
  directUrl = env("DIRECT_URL") // connexion directe (5432) — migrations/db push uniquement
}

// ─── MULTI-TENANT ROOT ───

model Organization {
  id                     String        @id @default(cuid())
  name                   String
  slug                   String        @unique
  logo                   String?
  plan                   Plan          @default(ESSENTIEL)
  billingCycle           BillingCycle?
  aiAddonEnabled         Boolean       @default(false)
  extraUsersCount        Int           @default(0)
  aiActionsUsedThisMonth Int           @default(0)
  aiActionsResetAt       DateTime      @default(now())
  planLockedUntil        DateTime?
  planChangedAt          DateTime?
  settings               Json          @default("{}") // Custom config: timezone, currency, etc.
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  webTrackingEnabled     Boolean       @default(false)
  reportingCustomEnabled Boolean       @default(false) // Rapports personnalisés activés (back-office)
  reportingAiEnabled     Boolean       @default(false) // Analyste IA activé (back-office)

  campuses             Campus[]
  users                User[]
  leads                Lead[]
  students             Student[]
  pipelineStages       PipelineStage[]
  pipelines            Pipeline[]
  academicYears        AcademicYear[]
  programs             Program[]
  messageTemplates     MessageTemplate[]
  campaigns            Campaign[]
  payments             Payment[]
  activities           Activity[]
  messages             Message[]
  automations          Automation[]
  emailCampaigns       EmailCampaign[]
  tasks                Task[]
  calls                Call[]
  appointments         Appointment[]
  portalTokens         LeadPortalToken[]
  sequenceExecutions   SequenceExecution[]
  workflows            Workflow[]
  workflowExecutions   WorkflowExecution[]
  sequenceConfig       OrganizationSequenceConfig?
  chatbotConfig        ChatbotConfig?
  whatsappWidgetConfig WhatsAppWidgetConfig?
  visitors             Visitor[]
  sessions             Session[]
  pageViews            PageView[]
  whatsappIntegration  WhatsAppIntegration?
  audiences            Audience[]
  whatsappTemplates    WhatsAppTemplate[]
  whatsappCampaigns    WhatsAppCampaign[]
  supportTickets       SupportTicket[]
  emailDomain          OrgEmailDomain?
  planChangeLogs       PlanChangeLog[]
  contracts            Contract[]
  reportingGoals       ReportingGoal[]
  customReports        CustomReport[]
  aiReportQueries      AiReportQuery[]
  reportDashboards     ReportDashboard[]
  folders              Folder[]

  @@map("organizations")
}

// Dossiers de rangement — partagés entre Documents et Templates email (discriminés
// par `type`). Plats (pas d'imbrication). Supprimer un dossier ne supprime pas son
// contenu : les documents/templates deviennent « sans dossier » (folderId = null).
model Folder {
  id             String     @id @default(cuid())
  organizationId String
  type           FolderType
  name           String
  createdAt      DateTime   @default(now())

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  libraryDocuments LibraryDocument[]
  messageTemplates MessageTemplate[]

  @@index([organizationId, type])
  @@map("folders")
}

enum FolderType {
  DOCUMENT // Bibliothèque de documents (/documents)
  EMAIL_TEMPLATE // Templates email (settings/email-templates)
}

enum Plan {
  ESSENTIEL
  CROISSANCE
  PERFORMANCE
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

// ─── CONTRATS D'ABONNEMENT ───
// Contrat papier : généré/pré-rempli côté CRM, imprimé, signé à la main par le
// client, puis re-uploadé (scan/photo) depuis le CRM. Le PDF signé est archivé
// dans Supabase (bucket privé « contracts ») et envoyé à contact@talibcrm.com.
model Contract {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan           Plan
  billingCycle   BillingCycle?
  reference      String         @unique // ex. TC-CRO-0001
  status         ContractStatus @default(BROUILLON)

  // Contenu éditable côté back-office (parties + clauses). Voir lib/contracts/template.ts
  content Json?

  // Utilisateurs de l'org autorisés à voir le contrat dans le CRM (désignés au back-office)
  allowedUserIds String[] @default([])

  // Fichier signé (renseigné à l'upload)
  signedPath     String? // chemin dans le bucket Supabase
  signedFileName String?
  signedSize     Int?
  signedMime     String?
  signedAt       DateTime? // date de réception du contrat signé
  uploadedById   String? // User (org) ayant fait l'upload
  uploadedByName String?

  // Validation côté back-office
  validatedAt DateTime?
  validatedBy String? // PlatformAdmin ayant validé
  note        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@map("contracts")
}

enum ContractStatus {
  BROUILLON // généré, pas encore présenté
  A_SIGNER // disponible pour le client, en attente de signature
  SIGNE_RECU // le client a re-uploadé le contrat signé
  VALIDE // validé par le back-office
}

enum SupportTicketType {
  BUG
  IMPROVEMENT
  QUESTION
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ─── CAMPUS & PROGRAMS ───

model Campus {
  id             String   @id @default(cuid())
  name           String
  city           String
  country        String   @default("SN") // ISO 3166-1 alpha-2
  address        String?
  phone          String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  programs     Program[]
  users        User[]
  leads        Lead[]
  students     Student[]

  @@index([organizationId])
  @@map("campuses")
}

enum FormationType {
  INITIAL // Formation Initiale (FI) - étudiants après bac
  CONTINUE // Formation Continue (FC) - professionnels
  BOTH // Les deux
}

enum AudienceType {
  STATIC // liste figée gérée manuellement
  DYNAMIC // basée sur des règles
  IMPORTED // snapshot d'un import CSV
}

model Program {
  id                String        @id @default(cuid())
  name              String // e.g. "BTS Comptabilité", "Licence Marketing"
  code              String? // e.g. "BTS-COMPTA"
  level             ProgramLevel
  durationMonths    Int // 12, 24, 36...
  tuitionAmount     Float // Annual tuition in FCFA
  currency          String        @default("XOF")
  isActive          Boolean       @default(true)
  campusId          String
  organizationId    String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  formationType     FormationType @default(INITIAL)
  pipelineId        String?
  targetEnrollments Int           @default(0) // Objectif d'inscrits (recrutement par programme)
  diploma           String? // Programme / diplôme de rattachement (ex. « Cycle Licence ») — regroupement dans le rapport recrutement

  campus       Campus       @relation(fields: [campusId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pipeline     Pipeline?    @relation(fields: [pipelineId], references: [id])
  leads        Lead[]
  students     Student[]
  subjects     Subject[]

  @@index([organizationId])
  @@index([campusId])
  @@index([pipelineId])
  @@map("programs")
}

enum ProgramLevel {
  BTS
  LICENCE
  MASTER
  DOCTORAT
  CERTIFICATE
  PROFESSIONAL
}

model AcademicYear {
  id             String   @id @default(cuid())
  label          String // e.g. "2025-2026"
  startDate      DateTime
  endDate        DateTime
  isCurrent      Boolean  @default(false)
  organizationId String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  enrollments  Enrollment[]
  payments     Payment[]

  @@unique([organizationId, label])
  @@index([organizationId])
  @@map("academic_years")
}

// ─── USERS & AUTH ───

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  name                  String
  phone                 String?
  passwordHash          String
  role                  UserRole
  avatar                String?
  isActive              Boolean   @default(true)
  emailVerified         DateTime? // null = email non vérifié (blocage souple à l'inscription)
  lastLoginAt           DateTime?
  emailSignature        String?   @db.Text // signature HTML ajoutée automatiquement aux emails
  emailSignatureEnabled Boolean   @default(true)
  organizationId        String
  campusId              String? // null = access to all campuses
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  organization             Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campus                   Campus?                  @relation(fields: [campusId], references: [id])
  assignedLeads            Lead[]                   @relation("AssignedLeads")
  activities               Activity[]
  sentMessages             Message[]                @relation("SentMessages")
  emailCampaigns           EmailCampaign[]          @relation("EmailCampaigns")
  assignedTasks            Task[]                   @relation("AssignedTasks")
  createdTasks             Task[]                   @relation("CreatedTasks")
  calls                    Call[]                   @relation("UserCalls")
  assignedAppointments     Appointment[]            @relation("AssignedAppointments")
  createdAppointments      Appointment[]            @relation("CreatedAppointments")
  integrations             UserIntegration[]
  portalTokens             LeadPortalToken[]
  audiencesCreated         Audience[]               @relation("AudiencesCreated")
  audienceMembersAdded     AudienceMember[]         @relation("AudienceMembersAdded")
  whatsappTemplatesCreated WhatsAppTemplate[]       @relation("WhatsAppTemplatesCreated")
  whatsappCampaignsCreated WhatsAppCampaign[]       @relation("WhatsAppCampaignsCreated")
  supportTickets           SupportTicket[]
  notifications            Notification[]
  emailVerificationTokens  EmailVerificationToken[]
  passwordResetTokens      PasswordResetToken[]

  @@index([organizationId])
  @@index([email])
  @@map("users")
}

// ─── VÉRIFICATION D'EMAIL & ANTI-ABUS ───

// Token à usage unique envoyé par email à l'inscription (blocage souple).
model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  email     String // email visé (permet de détecter un changement d'email)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

// Réinitialisation de mot de passe. On ne stocke QUE le hash SHA-256 du token
// (le token brut ne vit que dans le lien email) → une fuite de base est inexploitable.
model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// Limiteur d'inscriptions par IP (anti-abus du signup public).
model SignupThrottle {
  ip          String   @id
  count       Int      @default(0)
  windowStart DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("signup_throttles")
}

// ─── NOTIFICATIONS ───

model Notification {
  id             String   @id @default(cuid())
  userId         String // Destinataire
  organizationId String
  type           String   @default("TASK_REMINDER") // TASK_REMINDER, ...
  title          String
  body           String?
  taskId         String? // Tâche liée (optionnel)
  leadId         String? // Lead lié (optionnel)
  url            String? // Lien de destination au clic
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([organizationId])
  @@index([createdAt])
  @@map("notifications")
}

enum UserRole {
  SUPER_ADMIN // Platform-level admin
  ADMIN // School admin (full access)
  COMMERCIAL // Sales team
  TEACHER // Faculty
  ACCOUNTANT // Finance
  VIEWER // Read-only
}

// ─── RECRUITMENT PIPELINE ───

model Pipeline {
  id             String         @id @default(cuid())
  name           String
  description    String?
  formationType  FormationType? // INITIAL / CONTINUE / null (cas 1 pipeline)
  isDefault      Boolean        @default(false)
  isActive       Boolean        @default(true)
  order          Int            @default(0)
  color          String?
  organizationId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stages       PipelineStage[]
  leads        Lead[]
  programs     Program[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("pipelines")
}

model PipelineStage {
  id             String   @id @default(cuid())
  name           String // e.g. "Nouveau lead", "Contacté", "Dossier reçu"
  order          Int
  color          String   @default("#3B82F6") // Hex color for Kanban
  isDefault      Boolean  @default(false) // Stage for new leads
  isWon          Boolean  @default(false) // "Inscrit" stage
  isLost         Boolean  @default(false) // "Perdu" stage
  organizationId String
  pipelineId     String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pipeline     Pipeline?    @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  leads        Lead[]

  @@unique([organizationId, order])
  @@index([organizationId])
  @@index([pipelineId])
  @@map("pipeline_stages")
}

model Lead {
  id          String    @id @default(cuid())
  firstName   String
  lastName    String
  phone       String
  whatsapp    String? // May differ from phone
  email       String?
  civility    String?
  dateOfBirth DateTime?
  city        String? // City of origin
  country     String    @default("SN")
  message     String? // Message libre du formulaire de contact
  subject     String? // Objet / motif du message

  // Pipeline
  stageId      String
  pipelineId   String?
  score        Int        @default(0) // 0-100 lead score
  source       LeadSource
  sourceDetail String? // e.g. "Salon Dakar 2026", "Facebook Ad #123"

  // Assignment
  assignedToId String?
  programId    String? // Desired program
  campusId     String?
  campaignId   String?

  // Status
  isConverted Boolean   @default(false) // Became a student
  convertedAt DateTime?
  lostReason  String?

  customFields Json? // Stores unmapped/custom form fields

  // Dénormalisé : dernier contact (max appel / message OUTBOUND / RDV programmé-confirmé-terminé).
  // Mis à jour à chaque contact + réconcilié par le cron lead-scores. Évite 3 groupBy au rendu du pipeline.
  lastContactAt DateTime?

  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  stage        PipelineStage @relation(fields: [stageId], references: [id])
  pipeline     Pipeline?     @relation(fields: [pipelineId], references: [id])
  assignedTo   User?         @relation("AssignedLeads", fields: [assignedToId], references: [id])
  program      Program?      @relation(fields: [programId], references: [id])
  campus       Campus?       @relation(fields: [campusId], references: [id])
  campaign     Campaign?     @relation(fields: [campaignId], references: [id])
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  student                    Student? // 1:1 if converted
  activities                 Activity[]
  messages                   Message[]
  documents                  Document[]
  tasks                      Task[]
  calls                      Call[]
  appointments               Appointment[]
  portalTokens               LeadPortalToken[]
  sequenceExecutions         SequenceExecution[]
  aiAnalysis                 LeadAIAnalysis?
  visitors                   Visitor[]
  audienceMemberships        AudienceMember[]
  whatsappCampaignRecipients WhatsAppCampaignRecipient[] @relation("WhatsAppRecipientLead")

  @@index([organizationId])
  @@index([pipelineId])
  @@index([stageId])
  @@index([assignedToId])
  @@index([organizationId, createdAt])
  @@index([organizationId, lastContactAt])
  @@index([organizationId, phone]) // matching des webhooks WhatsApp/inbound sans scan
  @@map("leads")
}

enum LeadSource {
  WEBSITE
  FACEBOOK
  INSTAGRAM
  WHATSAPP
  PHONE_CALL
  WALK_IN
  REFERRAL
  SALON // Education fair
  RADIO
  TV
  PARTNER // e.g. Orientation Facile
  IMPORT
  OTHER
}

model Campaign {
  id             String       @id @default(cuid())
  name           String
  type           CampaignType
  startDate      DateTime?
  endDate        DateTime?
  budget         Float?
  currency       String       @default("XOF")
  isActive       Boolean      @default(true)
  organizationId String
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads        Lead[]

  @@index([organizationId])
  @@map("campaigns")
}

enum CampaignType {
  SOCIAL_MEDIA
  SALON
  RADIO
  TV
  REFERRAL
  EMAIL
  SMS
  WHATSAPP
  OUTDOOR
  OTHER
}

// ─── STUDENTS & ENROLLMENT ───

model Student {
  id             String        @id @default(cuid())
  studentNumber  String // Auto-generated, e.g. "EDU-2026-0001"
  leadId         String        @unique
  programId      String
  campusId       String
  status         StudentStatus @default(ACTIVE)
  enrollmentDate DateTime      @default(now())

  // Personal info (copied from lead, can be updated)
  firstName        String
  lastName         String
  civility         String?
  phone            String
  whatsapp         String?
  email            String?
  dateOfBirth      DateTime?
  address          String?
  emergencyContact String?
  emergencyPhone   String?

  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lead         Lead         @relation(fields: [leadId], references: [id])
  program      Program      @relation(fields: [programId], references: [id])
  campus       Campus       @relation(fields: [campusId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  enrollments Enrollment[]
  payments    Payment[]
  attendances Attendance[]
  grades      Grade[]
  documents   Document[]
  activities  Activity[]

  @@unique([organizationId, studentNumber])
  @@index([organizationId])
  @@index([programId])
  @@map("students")
}

enum StudentStatus {
  ACTIVE
  SUSPENDED // e.g. unpaid fees
  ON_LEAVE
  GRADUATED
  WITHDRAWN
  EXPELLED
}

model Enrollment {
  id             String           @id @default(cuid())
  studentId      String
  academicYearId String
  yearOfStudy    Int // 1, 2, 3...
  status         EnrollmentStatus @default(ENROLLED)
  enrolledAt     DateTime         @default(now())

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  @@unique([studentId, academicYearId])
  @@map("enrollments")
}

enum EnrollmentStatus {
  ENROLLED
  COMPLETED
  FAILED
  WITHDRAWN
}

// ─── ACADEMICS ───

model Subject {
  id          String   @id @default(cuid())
  name        String
  code        String?
  coefficient Float    @default(1)
  programId   String
  semester    Int? // 1, 2, etc.
  createdAt   DateTime @default(now())

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  grades  Grade[]

  @@index([programId])
  @@map("subjects")
}

model Grade {
  id        String    @id @default(cuid())
  studentId String
  subjectId String
  value     Float // 0-20 scale (French system)
  type      GradeType @default(EXAM)
  session   String? // "Session 1", "Rattrapage"
  createdAt DateTime  @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([subjectId])
  @@map("grades")
}

enum GradeType {
  EXAM
  CONTINUOUS // Contrôle continu
  PROJECT
  INTERNSHIP
}

model Attendance {
  id        String           @id @default(cuid())
  studentId String
  date      DateTime
  status    AttendanceStatus
  subjectId String?
  note      String?
  createdAt DateTime         @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date, subjectId])
  @@index([studentId])
  @@index([date])
  @@map("attendances")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

// ─── PAYMENTS ───

model Payment {
  id             String         @id @default(cuid())
  studentId      String
  academicYearId String
  label          String // "Tranche 1", "Frais d'inscription", etc.
  amount         Float
  currency       String         @default("XOF")
  dueDate        DateTime
  paidDate       DateTime?
  paidAmount     Float?
  method         PaymentMethod?
  transactionRef String? // Mobile Money transaction ID
  status         PaymentStatus  @default(PENDING)

  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([studentId])
  @@index([status])
  @@index([dueDate])
  @@map("payments")
}

enum PaymentMethod {
  ORANGE_MONEY
  WAVE
  MTN_MOMO
  CASH
  BANK_TRANSFER
  CHECK
  CARD
  OTHER
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
  REFUNDED
}

// ─── OBJECTIFS DE REPORTING (objectifs de rentrée) ───
// Cibles chiffrées sur une période (campagne de rentrée) affichées en jauges
// dans le hub Reporting. Une org peut définir plusieurs objectifs ; l'objectif
// « actif » est celui dont la période englobe la date du jour (sinon le plus récent).
model ReportingGoal {
  id                   String   @id @default(cuid())
  organizationId       String
  label                String // ex. « Rentrée 2026–2027 »
  startDate            DateTime
  endDate              DateTime
  targetEnrollments    Int      @default(0) // nouvelles inscriptions visées
  targetLeads          Int      @default(0) // leads à générer
  targetConversionRate Float? // taux de conversion cible (%)
  createdById          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("reporting_goals")
}

// ─── RAPPORTS PERSONNALISÉS ───
// Configuration d'un rapport sur mesure (source + dimension + mesure + période
// + visualisation), exécutée à la volée par le moteur report-engine. Le quota
// par org (3 ou 10) dépend du plan. Champs contraints à une whitelist serveur.
model CustomReport {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  source         String // "leads" | "students" | "appointments" | "calls"
  dimension      String // ex. "source", "program", "assignedTo"
  measure        String // ex. "count", "conversionRate"
  period         String   @default("90d") // "30d" | "90d" | "12m" | "all"
  vizType        String   @default("table") // "table" | "bar" | "pie"
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dashboardItems DashboardItem[]

  @@index([organizationId])
  @@map("custom_reports")
}

// ─── TABLEAUX DE BORD ───
// Un tableau de bord regroupe plusieurs rapports personnalisés (style HubSpot).
// Quota par plan : Croissance 1, Performance 5 (au-delà : sur devis).
model ReportDashboard {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items        DashboardItem[]

  @@index([organizationId])
  @@map("report_dashboards")
}

model DashboardItem {
  id          String @id @default(cuid())
  dashboardId String
  reportId    String
  position    Int    @default(0)
  width       String @default("half") // "half" | "full"

  dashboard ReportDashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  report    CustomReport    @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([dashboardId])
  @@map("dashboard_items")
}

// ─── ANALYSTE IA (Performance) ───
// Historique des questions en langage naturel : la question, la config de
// rapport déduite par l'IA (whitelist), et la narration générée à partir des
// chiffres réels. Sert d'historique + de re-visualisation.
model AiReportQuery {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  question       String
  source         String
  dimension      String
  measure        String
  period         String
  vizType        String
  answer         String // narration IA (analyse + recommandation)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@map("ai_report_queries")
}

// ─── COMMUNICATION ───

model Message {
  id          String           @id @default(cuid())
  leadId      String?
  studentId   String? // For post-enrollment comms
  channel     MessageChannel
  direction   MessageDirection
  content     String
  mediaUrl    String? // Attachment URL
  templateId  String?
  status      MessageStatus    @default(SENT)
  externalId  String? // WhatsApp/SMS provider message ID
  sentById    String? // User who sent it (null for automated)
  sentAt      DateTime         @default(now())
  deliveredAt DateTime?
  readAt      DateTime?

  // ─── NEW: WhatsApp tracking ───
  whatsappContactName String? // Nom WhatsApp du contact (ex: "Aminata D.")
  whatsappMediaType   String? // "image" | "audio" | "document" | "video" | null
  whatsappMediaId     String? // ID Meta du média (à télécharger plus tard)
  whatsappMediaUrl    String? // URL Supabase Storage si déjà téléchargé
  // ─── /NEW ───

  organizationId String
  createdAt      DateTime @default(now())

  lead         Lead?               @relation(fields: [leadId], references: [id])
  sentBy       User?               @relation("SentMessages", fields: [sentById], references: [id])
  template     MessageTemplate?    @relation(fields: [templateId], references: [id])
  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  events       MessageEvent[]
  attachments  MessageAttachment[]
  isCampaign   Boolean             @default(false)

  @@index([organizationId])
  @@index([leadId])
  @@index([studentId])
  @@index([channel])
  @@index([sentAt])
  @@index([externalId]) // NEW: anti-doublon webhook
  @@index([organizationId, sentAt]) // inbox : dernier message par lead, tri org
  @@index([leadId, sentAt]) // fil de conversation d'un lead
  @@map("messages")
}

enum MessageChannel {
  WHATSAPP
  SMS
  EMAIL
  PHONE_CALL // Log only
  IN_APP
  CHATBOT
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  REJECTED
}

model MessageTemplate {
  id             String           @id @default(cuid())
  name           String
  channel        MessageChannel
  subject        String? // For emails
  body           String // With variables: {{firstName}}, {{program}}, etc.
  blocks         Json? // Visual builder blocks
  brandColor     String?          @default("#1B4F72")
  variables      String[] // List of available variables
  category       TemplateCategory
  isApproved     Boolean          @default(false) // WhatsApp template approval
  whatsappId     String? // WhatsApp Business template ID
  folderId       String? // Dossier de rangement (optionnel)
  organizationId String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  folder       Folder?      @relation(fields: [folderId], references: [id], onDelete: SetNull)
  messages     Message[]

  @@index([organizationId])
  @@index([folderId])
  @@map("message_templates")
}

enum TemplateCategory {
  RECRUITMENT // Lead nurturing
  ENROLLMENT // Inscription process
  PAYMENT_REMINDER // Rappels de paiement
  ACADEMIC // Notes, emploi du temps
  GENERAL // Announcements
}

// ─── AUTOMATIONS ───

model Automation {
  id             String            @id @default(cuid())
  name           String
  description    String?
  trigger        AutomationTrigger
  triggerConfig  Json // e.g. { "stageId": "xxx" } or { "daysOverdue": 3 }
  action         AutomationAction
  actionConfig   Json // e.g. { "templateId": "xxx", "channel": "WHATSAPP" }
  isActive       Boolean           @default(true)
  organizationId String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("automations")
}

enum AutomationTrigger {
  LEAD_STAGE_CHANGED // Lead moves to a specific stage
  LEAD_NO_RESPONSE // No response after X days
  PAYMENT_DUE // Payment due in X days
  PAYMENT_OVERDUE // Payment overdue by X days
  ENROLLMENT_COMPLETE // Student just enrolled
  ATTENDANCE_ALERT // X consecutive absences
}

enum AutomationAction {
  SEND_WHATSAPP
  SEND_SMS
  SEND_EMAIL
  ASSIGN_LEAD
  CREATE_TASK
  UPDATE_STATUS
}

// ─── DOCUMENTS ───

model Document {
  id        String       @id @default(cuid())
  name      String
  type      DocumentType
  url       String // Vercel Blob / R2 URL
  mimeType  String
  size      Int // bytes
  leadId    String?
  studentId String?
  createdAt DateTime     @default(now())

  lead    Lead?    @relation(fields: [leadId], references: [id])
  student Student? @relation(fields: [studentId], references: [id])

  @@index([leadId])
  @@index([studentId])
  @@map("documents")
}

// Bibliothèque de documents de l'école (niveau organisation) — brochures, programmes,
// formulaires… téléversés une fois puis partagés avec prospects/étudiants.
// Auteur dénormalisé (pas de FK) pour une migration simple, sans contrainte.
model LibraryDocument {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  category       String   @default("Autre")
  path           String // chemin de stockage Supabase (bucket email-attachments, prefixe library/)
  mimeType       String
  size           Int // octets
  folderId       String? // Dossier de rangement (optionnel)
  uploadedById   String
  uploadedByName String
  createdAt      DateTime @default(now())

  folder Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([folderId])
  @@map("library_documents")
}

// Constructeur de formulaires : formulaires personnalisés (site web / lien / webinaire)
model Form {
  id               String   @id @default(cuid())
  organizationId   String
  name             String
  slug             String   @unique // global → URL /f/<slug>
  description      String?
  fields           Json // [{ id, type, label, name, required, placeholder?, help?, options[]?, width? }]
  settings         Json? // { submitLabel, successMode, successMessage, redirectUrl, color, buttonColor, bgColor, textColor, radius, logo, customCss }
  routing          Json? // { pipelineStageId?, assignToId?, tags[] }
  status           String   @default("DRAFT") // DRAFT | PUBLISHED
  submissionsCount Int      @default(0)
  createdById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  submissions FormSubmission[]

  @@index([organizationId])
  @@map("forms")
}

model FormSubmission {
  id             String   @id @default(cuid())
  formId         String
  organizationId String
  leadId         String? // lead créé à partir de cette soumission
  data           Json // valeurs brutes soumises
  createdAt      DateTime @default(now())

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@index([organizationId])
  @@map("form_submissions")
}

enum DocumentType {
  ID_CARD
  DIPLOMA
  TRANSCRIPT
  PHOTO
  ENROLLMENT_FORM
  RECEIPT
  CERTIFICATE
  OTHER
}

// ─── ACTIVITY LOG ───

model Activity {
  id             String       @id @default(cuid())
  type           ActivityType
  description    String
  metadata       Json? // Additional structured data
  userId         String? // Who performed the action
  leadId         String?
  studentId      String?
  organizationId String
  createdAt      DateTime     @default(now())

  user         User?        @relation(fields: [userId], references: [id])
  lead         Lead?        @relation(fields: [leadId], references: [id])
  student      Student?     @relation(fields: [studentId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([leadId])
  @@index([studentId])
  @@index([createdAt])
  @@map("activities")
}

enum ActivityType {
  LEAD_CREATED
  LEAD_STAGE_CHANGED
  LEAD_ASSIGNED
  LEAD_SCORED
  LEAD_CONVERTED
  LEAD_LOST
  MESSAGE_SENT
  MESSAGE_RECEIVED
  CALL_LOGGED
  NOTE_ADDED
  DOCUMENT_UPLOADED
  PAYMENT_RECEIVED
  PAYMENT_OVERDUE
  ENROLLMENT_CREATED
  GRADE_ENTERED
  ATTENDANCE_MARKED
  AUTOMATION_TRIGGERED
}

// ─── TASKS ───

model Task {
  id             String       @id @default(cuid())
  title          String
  description    String?
  type           TaskType     @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  status         TaskStatus   @default(TODO)
  dueDate        DateTime?
  completedAt    DateTime?
  reminderAt     DateTime?
  reminderSentAt DateTime? // Rappel déjà notifié (anti-doublon cron)

  // Relations
  leadId         String?
  assignedToId   String
  createdById    String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignedTo   User         @relation("AssignedTasks", fields: [assignedToId], references: [id])
  createdBy    User?        @relation("CreatedTasks", fields: [createdById], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([assignedToId])
  @@index([leadId])
  @@index([status])
  @@index([dueDate])
  @@index([reminderSentAt, reminderAt])
  @@map("tasks")
}

enum TaskType {
  TODO // Tâche générale
  CALL // Rappeler le lead
  EMAIL // Envoyer un email
  MEETING // Rendez-vous
  FOLLOW_UP // Relance
  DOCUMENT // Demander/envoyer un document
  OTHER
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

// ─── EMAIL CAMPAIGNS ───

model EmailCampaign {
  id               String              @id @default(cuid())
  name             String
  subject          String
  body             String
  status           EmailCampaignStatus @default(DRAFT)
  segmentRules     Json? // Filter criteria for leads
  scheduledAt      DateTime?
  sentAt           DateTime?
  completedAt      DateTime?
  totalRecipients  Int                 @default(0)
  sentCount        Int                 @default(0)
  deliveredCount   Int                 @default(0)
  openedCount      Int                 @default(0)
  clickedCount     Int                 @default(0)
  bouncedCount     Int                 @default(0)
  failedCount      Int                 @default(0)
  createdById      String?
  organizationId   String
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  audienceId       String?
  includeSignature Boolean             @default(true) // ajouter la signature de l'expéditeur en bas de chaque email
  audience         Audience?           @relation("CampaignAudience", fields: [audienceId], references: [id], onDelete: SetNull)

  createdBy    User?                    @relation("EmailCampaigns", fields: [createdById], references: [id])
  organization Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  recipients   EmailCampaignRecipient[]
  attachments  Json? // [{ path, filename, contentType, size }]

  @@index([organizationId])
  @@index([status])
  @@map("email_campaigns")
}

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
}

model EmailCampaignRecipient {
  id             String    @id @default(cuid())
  campaignId     String
  leadId         String
  email          String
  status         String    @default("PENDING") // PENDING, PROCESSING, SENT, DELIVERED, OPENED, CLICKED, BOUNCED, FAILED
  processingAt   DateTime? // horodatage du claim par le cron (récupération des claims orphelins)
  sentAt         DateTime?
  deliveredAt    DateTime?
  openedAt       DateTime?
  clickedAt      DateTime?
  bouncedAt      DateTime?
  brevoMessageId String?
  openCount      Int       @default(0)
  clickCount     Int       @default(0)
  errorMessage   String?

  campaign EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([campaignId, status])
  @@index([brevoMessageId])
  @@index([leadId]) // purge/fusion de leads sans scan de la table
  @@map("email_campaign_recipients")
}

// ─── CALLS ───

model Call {
  id           String        @id @default(cuid())
  leadId       String?
  direction    CallDirection
  outcome      CallOutcome
  duration     Int? // Durée en secondes
  phoneNumber  String // Numéro appelé/reçu
  notes        String?
  recordingUrl String?

  calledById     String // Commercial qui a passé/reçu l'appel
  organizationId String
  calledAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  calledBy     User         @relation("UserCalls", fields: [calledById], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([leadId])
  @@index([calledById])
  @@index([calledAt])
  @@map("calls")
}

enum CallDirection {
  INBOUND // Appel entrant
  OUTBOUND // Appel sortant
}

enum CallOutcome {
  ANSWERED // Décroché
  NO_ANSWER // Pas de réponse
  BUSY // Occupé
  VOICEMAIL // Messagerie
  CALLBACK // Rappeler plus tard
  WRONG_NUMBER // Mauvais numéro
  NOT_INTERESTED // Pas intéressé
}

// ─── APPOINTMENTS ───

model Appointment {
  id          String            @id @default(cuid())
  title       String
  description String?
  type        AppointmentType   @default(IN_PERSON)
  status      AppointmentStatus @default(SCHEDULED)

  startAt         DateTime
  endAt           DateTime
  location        String? // Adresse physique ou lien visio
  meetingUrl      String? // Google Meet / Zoom / Teams link
  meetingProvider String? // google_meet, zoom, teams

  leadId         String?
  assignedToId   String
  createdById    String?
  organizationId String

  // External calendar sync
  googleEventId  String?
  outlookEventId String?

  reminderAt DateTime?
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignedTo   User         @relation("AssignedAppointments", fields: [assignedToId], references: [id])
  createdBy    User?        @relation("CreatedAppointments", fields: [createdById], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([assignedToId])
  @@index([leadId])
  @@index([startAt])
  @@map("appointments")
}

enum AppointmentType {
  IN_PERSON // En présentiel
  PHONE // Par téléphone
  VIDEO_CALL // Visioconférence
}

enum AppointmentStatus {
  SCHEDULED // Planifié
  CONFIRMED // Confirmé
  IN_PROGRESS // En cours
  COMPLETED // Terminé
  CANCELLED // Annulé
  NO_SHOW // Absent
}

model UserIntegration {
  id           String    @id @default(cuid())
  userId       String
  provider     String // google_calendar
  accessToken  String
  refreshToken String?
  tokenExpiry  DateTime?
  accountEmail String?
  calendarId   String?   @default("primary")
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@map("user_integrations")
}

enum MessageEventType {
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  BLOCKED
  SPAM
  REPLIED
  FAILED
}

model MessageEvent {
  id        String           @id @default(cuid())
  messageId String?
  email     String?
  event     MessageEventType
  metadata  Json?
  createdAt DateTime         @default(now())

  message Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([messageId])
  @@index([email])
  @@map("message_events")
}

model MessageAttachment {
  id          String   @id @default(cuid())
  messageId   String
  filename    String
  contentType String?
  size        Int      @default(0)
  storagePath String? // Supabase path (for outbound)
  externalId  String? // Resend attachment ID (for inbound)
  downloadUrl String? // Cached signed URL (optional)
  createdAt   DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("message_attachments")
}

model ChatbotConfig {
  id             String   @id @default(cuid())
  organizationId String   @unique
  enabled        Boolean  @default(false)
  agentName      String   @default("Aïcha")
  welcomeMessage String   @default("Bonjour ! Comment puis-je vous aider ?")
  primaryColor   String   @default("#1B4F72")
  position       String   @default("bottom-right") // bottom-right, bottom-left
  scenario       Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("chatbot_configs")
}

// Bouton flottant « Cliquez pour discuter sur WhatsApp » embarqué sur le site
// de l'école. Réutilise le numéro Cloud API déjà configuré (WhatsAppIntegration).
// Les réponses des visiteurs remontent automatiquement dans l'inbox via le webhook.
model WhatsAppWidgetConfig {
  id               String   @id @default(cuid())
  organizationId   String   @unique
  enabled          Boolean  @default(false)
  title            String   @default("Entamer une conversation")
  welcomeMessage   String   @default("👋 Bonjour ! Cliquez ici pour échanger avec nous sur WhatsApp.")
  replyTimeText    String   @default("L'équipe répond généralement en quelques minutes.")
  prefilledMessage String   @default("Bonjour, je viens de votre site web et j'ai une question.")
  primaryColor     String   @default("#25D366")
  position         String   @default("bottom-right") // bottom-right, bottom-left
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("whatsapp_widget_configs")
}

model LeadPortalToken {
  id             String    @id @default(cuid())
  token          String    @unique
  leadId         String
  organizationId String
  expiresAt      DateTime
  lastAccessedAt DateTime?
  accessCount    Int       @default(0)
  createdAt      DateTime  @default(now())
  createdById    String?

  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([token])
  @@map("lead_portal_tokens")
}

model SequenceExecution {
  id             String   @id @default(cuid())
  leadId         String
  organizationId String
  stepName       String // "J1_email", "J3_whatsapp", "J7_call_task", "J14_last_chance", "J21_auto_lost"
  executedAt     DateTime @default(now())
  status         String   @default("DONE") // DONE, FAILED, SKIPPED
  metadata       Json?

  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([leadId, stepName])
  @@index([leadId])
  @@index([organizationId])
  @@index([stepName])
  @@map("sequence_executions")
}

model OrganizationSequenceConfig {
  id                    String   @id @default(cuid())
  organizationId        String   @unique
  enabled               Boolean  @default(false)
  pauseOnReply          Boolean  @default(true)
  pauseOnAppointment    Boolean  @default(true)
  autoMarkLostAfterDays Int      @default(21)
  steps                 Json     @default("[]")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_sequence_configs")
}

model Workflow {
  id          String  @id @default(cuid())
  name        String
  description String?
  enabled     Boolean @default(false)

  // Trigger config
  triggerType   String // LEAD_CREATED, STAGE_CHANGED, NO_RESPONSE_DAYS, EMAIL_OPENED, etc.
  triggerConfig Json   @default("{}")

  // Steps as a JSON graph (nodes + edges)
  // Format: { nodes: [{id, type, data, position}], edges: [{id, source, target, sourceHandle?}] }
  graph Json @default("{\"nodes\":[],\"edges\":[]}")

  organizationId String
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  executions   WorkflowExecution[]

  @@index([organizationId])
  @@index([enabled])
  @@map("workflows")
}

model WorkflowExecution {
  id           String    @id @default(cuid())
  workflowId   String
  leadId       String?
  status       String    @default("RUNNING") // RUNNING, COMPLETED, FAILED, WAITING
  currentNode  String? // ID du noeud en cours d'exécution
  context      Json      @default("{}") // Variables disponibles dans le workflow
  waitUntil    DateTime? // Pour les noeuds "Attendre X temps"
  completedAt  DateTime?
  errorMessage String?

  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workflow     Workflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([leadId])
  @@index([status])
  @@index([waitUntil])
  @@index([organizationId])
  @@map("workflow_executions")
}

model LeadAIAnalysis {
  id     String @id @default(cuid())
  leadId String @unique

  // Cached AI analyses (JSON for flexibility)
  briefData   Json?
  actionsData Json?

  // Snapshot of lead state at analysis time (for change detection)
  snapshotMessageCount     Int     @default(0)
  snapshotCallCount        Int     @default(0)
  snapshotAppointmentCount Int     @default(0)
  snapshotTaskCount        Int     @default(0)
  snapshotStageId          String?
  snapshotScore            Int     @default(0)
  snapshotIsConverted      Boolean @default(false)

  briefGeneratedAt   DateTime?
  actionsGeneratedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("lead_ai_analyses")
}

model Visitor {
  id        String @id @default(cuid())
  visitorId String // Cookie ID côté navigateur

  // Lead linkage
  leadId         String?
  organizationId String

  // Fingerprint (capté à la 1ère visite)
  userAgent  String? @db.Text
  language   String?
  screenSize String?
  timezone   String?

  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  sessions     Session[]
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@unique([visitorId, organizationId])
  @@index([leadId])
  @@index([organizationId])
  @@map("visitors")
}

model Session {
  id          String @id @default(cuid())
  visitorDbId String
  sessionId   String @unique // ID généré côté navigateur

  // Source captée au démarrage de la session
  referrer    String? @db.Text
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?
  gclid       String?
  fbclid      String?

  // Cycle de vie
  startedAt      DateTime  @default(now())
  lastActivityAt DateTime  @default(now())
  endedAt        DateTime?

  // Métriques d'engagement (issues des heartbeats)
  engagedTimeMs Int @default(0)
  pageviewCount Int @default(0)

  organizationId String

  pageViews    PageView[]
  visitor      Visitor      @relation(fields: [visitorDbId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([visitorDbId])
  @@index([organizationId, startedAt])
  @@map("sessions")
}

model PageView {
  id          String @id @default(cuid())
  sessionDbId String

  url   String  @db.Text
  path  String
  title String?

  engagedTimeMs Int @default(0)

  organizationId String
  viewedAt       DateTime @default(now())

  session      Session      @relation(fields: [sessionDbId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([sessionDbId])
  @@index([organizationId, viewedAt])
  @@index([path])
  @@map("page_views")
}

model WhatsAppIntegration {
  id             String @id @default(cuid())
  organizationId String @unique

  // Credentials Meta (chiffrés idéalement, mais en clair pour MVP)
  phoneNumberId             String // ID du numéro côté Meta
  whatsappBusinessAccountId String // WABA ID
  accessToken               String @db.Text // Permanent token
  verifyToken               String // Pour la vérification webhook (l'école choisit une chaîne)
  appSecret                 String @db.Text // App Secret pour vérifier signatures webhook

  // Métadonnées
  displayPhoneNumber String? // Le numéro lisible (+221 XX XXX XX XX)
  verifiedName       String? // Nom vérifié Meta (ex: "BEM Dakar Business")

  // État
  isActive     Boolean   @default(true)
  lastSyncedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("whatsapp_integrations")
}

model Audience {
  id          String       @id @default(cuid())
  name        String
  description String?
  type        AudienceType @default(STATIC)
  color       String? // couleur d'affichage

  // Règles pour DYNAMIC (JSON FilterGroup)
  // Format : { operator: "AND"|"OR", rules: [{ field, operator, value } | nestedGroup] }
  rules Json?

  // Metadata pour IMPORTED
  importMetadata Json? // { filename, importedAt, importedRows, skippedRows }

  // Stats (mises à jour à chaque évaluation)
  memberCount     Int       @default(0)
  lastEvaluatedAt DateTime? // dernière fois qu'on a compté pour DYNAMIC

  organizationId String
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy         User               @relation("AudiencesCreated", fields: [createdById], references: [id])
  members           AudienceMember[]
  campaigns         EmailCampaign[]    @relation("CampaignAudience")
  whatsappCampaigns WhatsAppCampaign[] @relation("WhatsAppCampaignAudience")

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([type])
  @@map("audiences")
}

model AudienceMember {
  id         String   @id @default(cuid())
  audienceId String
  leadId     String
  addedAt    DateTime @default(now())
  addedById  String? // user qui a ajouté (null si auto via import)

  audience Audience @relation(fields: [audienceId], references: [id], onDelete: Cascade)
  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  addedBy  User?    @relation("AudienceMembersAdded", fields: [addedById], references: [id])

  @@unique([audienceId, leadId])
  @@index([audienceId])
  @@index([leadId])
  @@map("audience_members")
}

// ═══════════════════════════════════════════════
// ═══ WhatsApp Campaigns Module ═══
// ═══════════════════════════════════════════════

enum WhatsAppCampaignStatus {
  DRAFT
  SCHEDULED // envoi programmé (promu en SENDING par le cron à l'échéance)
  SENDING
  SENT
  CANCELLED
  FAILED
}

enum WhatsAppRecipientStatus {
  PENDING
  PROCESSING // claimé par le cron d'envoi (anti double-envoi)
  SENT
  DELIVERED
  READ
  FAILED
}

enum WhatsAppTemplateStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  DISABLED
}

enum WhatsAppTemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
}

model WhatsAppTemplate {
  id             String @id @default(cuid())
  organizationId String

  metaName       String
  metaTemplateId String?
  language       String                   @default("fr")
  category       WhatsAppTemplateCategory @default(MARKETING)
  status         WhatsAppTemplateStatus   @default(DRAFT)

  bodyText   String  @db.Text
  headerText String? @db.Text
  footerText String? @db.Text

  buttons         Json?
  variableMapping Json?

  rejectionReason String?   @db.Text
  submittedAt     DateTime?
  approvedAt      DateTime?

  source String @default("local")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("WhatsAppTemplatesCreated", fields: [createdById], references: [id], onDelete: SetNull)

  campaigns WhatsAppCampaign[]

  @@unique([organizationId, metaName, language])
  @@index([organizationId, status])
  @@map("whatsapp_templates")
}

model WhatsAppCampaign {
  id             String @id @default(cuid())
  organizationId String

  name String

  audienceId   String?
  segmentRules Json?

  templateId String

  status WhatsAppCampaignStatus @default(DRAFT)

  totalRecipients Int @default(0)
  sentCount       Int @default(0)
  deliveredCount  Int @default(0)
  readCount       Int @default(0)
  failedCount     Int @default(0)

  scheduledAt DateTime?
  sentAt      DateTime?
  completedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  audience     Audience?        @relation("WhatsAppCampaignAudience", fields: [audienceId], references: [id], onDelete: SetNull)
  template     WhatsAppTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  createdBy    User?            @relation("WhatsAppCampaignsCreated", fields: [createdById], references: [id], onDelete: SetNull)

  recipients WhatsAppCampaignRecipient[]

  @@index([organizationId, status])
  @@map("whatsapp_campaigns")
}

model WhatsAppCampaignRecipient {
  id         String @id @default(cuid())
  campaignId String
  leadId     String

  whatsappNumber String

  status       WhatsAppRecipientStatus @default(PENDING)
  processingAt DateTime? // horodatage du claim par le cron (récupération des claims orphelins)

  metaMessageId String? @unique

  variableValues Json?

  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?

  errorCode    String?
  errorMessage String? @db.Text

  createdAt DateTime @default(now())

  campaign WhatsAppCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead     Lead             @relation("WhatsAppRecipientLead", fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([campaignId, leadId])
  @@index([metaMessageId])
  @@map("whatsapp_campaign_recipients")
}

// ─── BACK-OFFICE PLATEFORME (découplé des organisations) ───

model PlatformAdmin {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         String    @default("SUPPORT") // OWNER | ADMIN | SUPPORT
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  planChanges PlanChangeLog[]

  @@map("platform_admins")
}

// Audit des changements de plan effectués depuis le back-office
model PlanChangeLog {
  id             String    @id @default(cuid())
  organizationId String
  changedById    String? // PlatformAdmin auteur du changement
  fromPlan       String
  toPlan         String
  temporaryUntil DateTime? // si activation temporaire (essai)
  note           String?
  createdAt      DateTime  @default(now())

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  changedBy    PlatformAdmin? @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([createdAt])
  @@map("plan_change_logs")
}

// ─── DOMAINE EMAIL PERSONNALISÉ (par organisation) ───

model OrgEmailDomain {
  id             String    @id @default(cuid())
  organizationId String    @unique
  domain         String    @unique // ex. bemtech.sn — unicité inter-organisation
  fromLocalPart  String    @default("admission") // partie avant @ (admission@bemtech.sn)
  fromName       String? // nom d'affichage (sinon = nom de l'organisation)
  status         String    @default("PENDING") // PENDING | VERIFIED | FAILED
  resendDomainId String? // id du domaine côté Resend
  dnsRecords     Json? // enregistrements DNS renvoyés par Resend (à afficher)
  verifiedAt     DateTime?

  // ─── Réception (Phase 2) — domaine Resend distinct "reply.<domaine>" pour isoler le MX du root ───
  inboundSubdomain      String    @default("reply") // sous-domaine dédié à la réception (jamais le root)
  inboundStatus         String? // null=désactivée | PENDING | VERIFIED | FAILED
  inboundResendDomainId String? // id du domaine "reply.<domaine>" côté Resend
  inboundMxRecords      Json? // enregistrement(s) MX à ajouter (réception)
  inboundVerifiedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("org_email_domains")
}

model SupportTicket {
  id             String                @id @default(cuid())
  type           SupportTicketType     @default(BUG)
  priority       SupportTicketPriority @default(MEDIUM)
  status         SupportTicketStatus   @default(OPEN)
  title          String
  description    String
  screenshotPath String?
  pageUrl        String?
  organizationId String
  submittedById  String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  submittedBy  User?        @relation(fields: [submittedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([status])
  @@map("support_tickets")
}

// ─── Vues de prospects enregistrées (par conseiller) ───
// Vue filtrée nommée et épinglable de la liste des prospects, propre à chaque
// utilisateur. Stocke les filtres, les colonnes visibles et le tri. Isolation
// par organizationId + userId (scalaires indexés, pas de relation navigable).
model LeadView {
  id             String   @id @default(cuid())
  name           String
  organizationId String
  userId         String
  pipelineId     String? // vue rattachée à un pipeline (null = tous)
  filters        Json? // { search?, stage?, source?, assigned?, program?, campus?, mine?, toQualify?, advanced? }
  columns        String[] // clés des colonnes visibles, dans l'ordre
  sortKey        String?
  sortDir        String? // "asc" | "desc"
  isPinned       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, userId])
  @@map("lead_views")
}
